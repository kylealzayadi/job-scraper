{
  "manifest_version": 3,
  "name": "Job Info Scraper",
  "version": "1.0",
  "description": "Scrape job info from current page and send to Google Sheets.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Info Scraper",
    "default_icon": "icons8-dead-by-daylight-64.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
